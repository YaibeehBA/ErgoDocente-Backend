# ============================================
# APLICACIÓN
# ============================================
APP_NAME=ErgoDocente API
APP_VERSION=1.0.0
APP_ENV=development  # Opciones: development, staging, production, testing
DEBUG=True
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:8000"]

# ============================================
# API
# ============================================
API_V1_PREFIX=/api/v1

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ergodocente_db
POSTGRES_SCHEMA=public

# Pool de conexiones
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ============================================
# CLOUDINARY
# ============================================
# Obtén tus credenciales en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER_BASE=ergodocente

# ============================================
# SEGURIDAD / JWT (preparado para V2)
# ============================================
# Genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia-esta-clave-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=15

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO  # Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Opciones: json, console

# ============================================
# PAGINACIÓN
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100